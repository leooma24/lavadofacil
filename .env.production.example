###############################################################################
# LavadoFácil — .env de PRODUCCIÓN
#
# Antes de usar:
#   1. cp .env.production.example .env
#   2. php artisan key:generate         (regenera APP_KEY — NO reuses la de local)
#   3. Reemplaza todos los CHANGE_ME_*
#   4. chmod 640 .env && chown www-data:www-data .env
#   5. php artisan config:cache && php artisan route:cache && php artisan view:cache
###############################################################################

APP_NAME=LavadoFácil
APP_ENV=production
APP_KEY=CHANGE_ME_RUN_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://lavadofacil.tu-app.co
CENTRAL_DOMAIN=lavadofacil.tu-app.co

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_TIMEZONE=America/Mazatlan

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ───── Logs ─────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ───── Base de datos central ─────
# IMPORTANTE: usuario dedicado, NO root. Debe tener privilegios para CREATE DATABASE
# (los crea stancl/tenancy al dar de alta cada tenant -> tenant_{slug}).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lavadofacil_central
DB_USERNAME=lavadofacil
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ───── Sesiones / Cache / Cola ─────
# Sin Redis (VPS con RAM apretada). Cuando subas plan de hosting, migrar a redis.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# null = el browser usa el host exacto. NO uses .lavadofacil.tu-app.co (con punto)
# porque rompe la cookie en path-based tenancy.
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=lavadofacil

# ───── Correo (Gmail por ahora — migrar a Resend/SES después) ─────
MAIL_MAILER=smtp
MAIL_HOST=smtp.googlemail.com
MAIL_PORT=465
MAIL_USERNAME=leooma24@gmail.com
MAIL_PASSWORD="CHANGE_ME_APP_PASSWORD_LAVADOFACIL_PROD"
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@lavadofacil.tu-app.co"
MAIL_FROM_NAME="${APP_NAME}"

# ───── AWS / S3 (sin uso por ahora) ─────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ───── Vite ─────
VITE_APP_NAME="${APP_NAME}"

# ───── Tenancy (stancl) ─────
# El prefix de las BD por tenant lo maneja config/tenancy.php (tenant_{slug}).
# El usuario DB_USERNAME debe poder crear y migrar bases con ese prefijo.

# ───── Filament ─────
# Si usas notificaciones broadcast en el panel, sube esto. Por ahora no aplica.
